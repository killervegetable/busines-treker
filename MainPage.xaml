<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:busines_treker"
    x:Class="busines_treker.MainPage"
    BackgroundColor="#000000">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Colors -->
            <Color x:Key="BackgroundColor">#000000</Color>
            <Color x:Key="CardBackground">#1C1C1E</Color>
            <Color x:Key="SecondaryText">#8E8E93</Color>
            <Color x:Key="Separator">#2C2C2E</Color>
            <Color x:Key="AccentYellow">#FFD60A</Color>

            <!-- Styles -->
            <Style x:Key="CardFrame" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="ItemFrame" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="AmountLabel" TargetType="Label">
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="HorizontalOptions" Value="End" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="CategoryTitle" TargetType="Label">
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontSize" Value="16" />
            </Style>

            <Style x:Key="SecondarySmall" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="{StaticResource SecondaryText}" />
            </Style>

            <Style x:Key="FabButton" TargetType="Button">
                <Setter Property="WidthRequest" Value="60" />
                <Setter Property="HeightRequest" Value="60" />
                <Setter Property="CornerRadius" Value="30" />
                <Setter Property="BackgroundColor" Value="{StaticResource AccentYellow}" />
                <Setter Property="TextColor" Value="#000000" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="Shadow" Value="0,6,10,#00000066" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- Root layout with padding 20 -->
    <Grid Padding="20" RowSpacing="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <Label Text="{x:Static local:Loc.Title}" FontSize="22" TextColor="White" VerticalOptions="Center" />
            <Label x:Name="CurrentDateLabel" Grid.Column="1" TextColor="#BFBFBF" VerticalOptions="Center" HorizontalOptions="End" />
        </Grid>

        <!-- Segment controls (kept minimal) -->
        <StackLayout Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Text="Месяц" BackgroundColor="#111111" TextColor="White" CornerRadius="18" Padding="12,6" />
            <Button Text="Год" BackgroundColor="#111111" TextColor="White" CornerRadius="18" Padding="12,6" />
        </StackLayout>

        <!-- Chart + Legend wrapped by card (outer Frame) -->
        <Frame Grid.Row="2"
               Style="{StaticResource CardFrame}"
               BackgroundColor="{StaticResource CardBackground}">
            <!-- keep ChartGrid name (used in code-behind) as an inner Grid -->
            <Grid x:Name="ChartGrid" ColumnSpacing="12" RowSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Donut area (left) -->
                <Frame BackgroundColor="Transparent" CornerRadius="12" HasShadow="False" Padding="12">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                        <GraphicsView x:Name="DonutChartView" HeightRequest="180" WidthRequest="180">
                            <GraphicsView.GestureRecognizers>
                                <TapGestureRecognizer Tapped="DonutTapped" NumberOfTapsRequired="1" />
                            </GraphicsView.GestureRecognizers>
                        </GraphicsView>
                        <Label x:Name="DonutCenterLabel" Text="Март 2025" TextColor="White" HorizontalOptions="Center" Margin="0,8,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="DonutTapped" NumberOfTapsRequired="1" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </Frame>

                <!-- Legend area (right) -->
                <CollectionView x:Name="CategoryList" Grid.Column="1" ItemsLayout="VerticalList" BackgroundColor="Transparent" Margin="0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" ColumnDefinitions="24,*,Auto" VerticalOptions="Center">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLegendItemTapped" />
                                </Grid.GestureRecognizers>
                                <BoxView Color="{Binding Color}" WidthRequest="14" HeightRequest="14" CornerRadius="7" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding Name}" TextColor="White" FontSize="14" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding Percentage, StringFormat='{}{0:P1}'}" TextColor="#BFBFBF" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Frame>

        <!-- Transactions header -->
        <Label Grid.Row="3" Text="Транзакции" TextColor="White" FontAttributes="Bold" Margin="0,12,0,8" />

        <!-- Expenses list as modern cards -->
        <CollectionView x:Name="ExpensesList" Grid.Row="3" Margin="0,40,0,0" SelectionMode="None" ItemsLayout="VerticalList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Execute">
                                <SwipeItem Text="Удалить" BackgroundColor="#E53935" Invoked="OnDeleteSwipeItemInvoked" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Frame Style="{StaticResource ItemFrame}" Padding="10" HasShadow="False">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                                <!-- Icon placeholder -->
                                <Frame BackgroundColor="#111111" Padding="6" CornerRadius="8" HasShadow="False" VerticalOptions="Center">
                                    <Label Text="💳" FontSize="18" TextColor="White" />
                                </Frame>

                                <!-- Text block -->
                                <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Category}" Style="{StaticResource CategoryTitle}" />
                                    <Label Text="{Binding Note}" Style="{StaticResource SecondarySmall}" />
                                </StackLayout>

                                <!-- Amount -->
                                <Label Grid.Column="2" Text="{Binding Amount, StringFormat='{}{0:C}'}" Style="{StaticResource AmountLabel}" VerticalOptions="Center" />
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Floating action button (bottom-right) using AbsoluteLayout overlay -->
        <AbsoluteLayout Grid.RowSpan="4">
            <Button x:Name="AddFab"
                    Style="{StaticResource FabButton}"
                    Text="+"
                    Clicked="AddFab_Clicked"
                    AbsoluteLayout.LayoutFlags="PositionProportional"
                    AbsoluteLayout.LayoutBounds="1,1,60,60"
                    Margin="24" />
        </AbsoluteLayout>

        <!-- Overlay for adding expense (keeps existing names for code-behind) -->
        <Grid x:Name="AddOverlay" IsVisible="False" BackgroundColor="#80000000" Grid.RowSpan="4">
            <Grid HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="360" Margin="20">
                <Frame BackgroundColor="{StaticResource CardBackground}" CornerRadius="12" Padding="16" HasShadow="False">
                    <VerticalStackLayout Spacing="12">
                        <Entry x:Name="AmountEntry" Placeholder="{x:Static local:Loc.AmountPlaceholder}" Keyboard="Numeric" TextColor="White" />
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Picker x:Name="CategoryPicker" Title="{x:Static local:Loc.CategoryPlaceholder}" HorizontalOptions="FillAndExpand" />
                            <Button x:Name="AddCategoryButton" Text="+" WidthRequest="40" Clicked="AddCategory_Clicked" />
                        </HorizontalStackLayout>
                        <Entry x:Name="NoteEntry" Placeholder="{x:Static local:Loc.NotePlaceholder}" TextColor="White" />
                        <HorizontalStackLayout Spacing="12" HorizontalOptions="End">
                            <Button Text="Отмена" BackgroundColor="#333333" TextColor="White" Clicked="CancelAdd_Clicked" />
                            <Button Text="Сохранить" BackgroundColor="{StaticResource AccentYellow}" TextColor="#000" Clicked="SaveAdd_Clicked" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </Grid>

    </Grid>
</ContentPage>
