<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:busines_treker"
             x:Class="busines_treker.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Label
                Text="{x:Static local:Loc.Title}"
                FontSize="32"
                HorizontalOptions="Center" />

            <Entry x:Name="AmountEntry" Placeholder="{x:Static local:Loc.AmountPlaceholder}" Keyboard="Numeric" />
            <Entry x:Name="CategoryEntry" Placeholder="{x:Static local:Loc.CategoryPlaceholder}" />
            <Entry x:Name="NoteEntry" Placeholder="{x:Static local:Loc.NotePlaceholder}" />

            <Button
                x:Name="AddBtn"
                Text="{x:Static local:Loc.AddButton}"
                Clicked="AddExpense_Clicked" />

            <CollectionView x:Name="ExpensesList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout Padding="10">
                            <Label Text="{Binding Date, StringFormat='{0:dd.MM.yyyy}'}" />
                            <Label Text="{Binding Amount, StringFormat='{}{0:C}'}" />
                            <Label Text="{Binding Category}" />
                            <Label Text="{Binding Note}" />
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
